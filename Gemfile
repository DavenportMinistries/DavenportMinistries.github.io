source "https://rubygems.org"

# github-pages bundles jekyll + compatible plugins for GitHub Pages deployment.
# If local bundle install fails due to Ruby < 3.0, use jekyll directly below
# or install a newer Ruby: brew install ruby
gem "github-pages", group: :jekyll_plugins
gem "webrick"

# Uncomment the two lines below and comment out github-pages above
# if you need to run locally on Ruby 2.6:
# gem "jekyll", "~> 3.9"
# gem "webrick"
